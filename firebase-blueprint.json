{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user, including balance and referral data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "package": { "type": "string" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "lastDailyTask": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "balance", "role", "package", "referralCode", "createdAt"]
    },
    "Task": {
      "title": "Video Task",
      "description": "Video tasks that users can complete to earn rewards.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "reward": { "type": "number" },
        "videoUrl": { "type": "string", "format": "uri" },
        "duration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "reward", "videoUrl", "duration", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of financial movement in the user account.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "earning", "package_purchase", "referral_bonus"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed"] },
        "details": { "type": "string" },
        "cryptoAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User storage and profile mappings."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Collection of available earnable tasks."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Ledger of all financial activity."
    }
  }
}
